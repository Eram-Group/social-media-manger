# ─────────────────────────────────────────────────────────────────────────────
# EPCC env template. Copy to `.env.local` (gitignored) and fill in real values.
#   cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of this app. Used to build OAuth redirect URIs.
# Local dev:
APP_BASE_URL=http://localhost:3000
# Production example: APP_BASE_URL=https://your-app.vercel.app

# Database (Neon/Postgres). When set, connected accounts persist here (works on
# Vercel). When unset, a local .data/ JSON file is used (dev only).
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Vercel Blob (image hosting for Instagram posting)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── Meta (Facebook + Instagram) ──────────────────────────────────────────────
# From developers.facebook.com -> your app -> Settings -> Basic.
# SERVER-ONLY secrets — do NOT prefix with NEXT_PUBLIC_ (that would leak them).
META_APP_ID=
META_APP_SECRET=
# Optional: pin the Graph API version (default v21.0). Bump if Meta deprecates it.
# META_GRAPH_VERSION=v21.0
# Optional: override Instagram OAuth scopes if your app uses the newer
# "Instagram API with Instagram Login" product:
# META_INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish

# ── OpenAI (currently client-side; will move server-side) ────────────────────
# NEXT_PUBLIC_OPENAI_API_KEY=sk-...
# NEXT_PUBLIC_ENABLE_MSW=false
